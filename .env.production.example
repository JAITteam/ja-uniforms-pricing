# ============================================
# J.A. UNIFORMS - Production Environment
# ============================================
# Copy this file to .env.production and update values
# cp .env.production.example .env.production
# ============================================

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# IMPORTANT: Generate a new secret key for production!
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-production-secret-key-change-this-now

# ============================================
# DATABASE (PostgreSQL - Recommended for Production)
# ============================================
DATABASE_URL=postgresql://ja_uniforms_user:your_password_here@localhost:5432/ja_uniforms

# For SQLite (Development only - NOT recommended for production)
# DATABASE_URL=sqlite:///uniforms.db

# ============================================
# EMAIL CONFIGURATION (Gmail/Google Workspace)
# ============================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@jauniforms.com
MAIL_PASSWORD=your-app-password-here
MAIL_DEFAULT_SENDER=noreply@jauniforms.com

# ============================================
# ADMIN CONFIGURATION
# ============================================
# Users with these emails automatically get admin role on registration
# Separate multiple emails with commas (no spaces)
ADMIN_EMAILS=it@jauniforms.com,admin@jauniforms.com

# ============================================
# SERVER CONFIGURATION
# ============================================
# Bind address (0.0.0.0 allows network access)
HOST_IP=0.0.0.0
PORT=5000

# Gunicorn workers (leave blank for auto)
GUNICORN_WORKERS=

# ============================================
# BACKUP CONFIGURATION
# ============================================
BACKUP_DIR=/var/backups/ja_uniforms/database
FILE_BACKUP_DIR=/var/backups/ja_uniforms/files
BACKUP_KEEP_DAYS=30
BACKUP_KEEP_WEEKLY=12
BACKUP_KEEP_MONTHLY=12

# ============================================
# SECURITY (Enable for HTTPS deployments)
# ============================================
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# ============================================
# NOTES:
# ============================================
# 
# 1. SECRET_KEY:
#    Generate with: python -c "import secrets; print(secrets.token_hex(32))"
#    NEVER share this key or commit it to git!
#
# 2. DATABASE_URL for PostgreSQL:
#    postgresql://username:password@host:port/database
#    Example: postgresql://ja_uniforms_user:MySecurePass123@localhost:5432/ja_uniforms
#
# 3. MAIL_PASSWORD for Gmail:
#    Use an "App Password" - NOT your regular password
#    Generate at: Google Account > Security > 2-Step Verification > App Passwords
#
# 4. Network Access:
#    To allow other computers on your network to access the app:
#    - Set HOST_IP=0.0.0.0
#    - Configure firewall to allow port 5000
#    - Access via http://YOUR_IP:5000
#
# ============================================
